<Window x:Class="ChemistryApp.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:ChemistryApp.ViewModels" Title="Химия: Справочная система" Height="540" Width="1360" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Справка"/>
        </Menu>
        <StackPanel DockPanel.Dock="Left" Width="220" Background="#F5F5F5" Margin="0,0,10,0">
            <TextBlock Text="Темы" FontWeight="Bold" FontSize="18" Margin="10,15,10,10" TextAlignment="Center"/>
            <ListBox ItemsSource="{Binding Topics}" BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Height="58" Width="190" Margin="0,4" Padding="5" HorizontalAlignment="Center" Command="{Binding DataContext.SelectTopicCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="Таблица Менделеева" Height="58" Width="190" Margin="0,4" Padding="5" HorizontalAlignment="Center" FontSize="13" Command="{Binding OpenPeriodicTableCommand}"/>
        </StackPanel>
        <ContentControl Content="{Binding CurrentView}" Margin="10"/>
    </DockPanel>
</Window>