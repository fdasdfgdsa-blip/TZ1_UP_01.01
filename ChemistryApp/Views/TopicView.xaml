<UserControl x:Class="ChemistryApp.Views.TopicView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="20" Background="#FAFAFA">
        <StackPanel>
            <TextBlock x:Name="HeaderText" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1976D2"/>
            <TextBlock x:Name="ContentText" TextWrapping="Wrap" FontSize="15" LineHeight="26" Foreground="#333"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>