<UserControl x:Class="ChemistryApp.Views.PeriodicTableView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:ChemistryApp.ViewModels">
    <UserControl.DataContext>
        <vm:PeriodicTableViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,0,10">
            <TextBlock Text="🔍 Поиск: " VerticalAlignment="Center" FontSize="15" Margin="0,0,5,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" Width="280" Height="30" FontSize="14"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#FAFAFA" Margin="10,0,10,0" CornerRadius="8">
                <ItemsControl ItemsSource="{Binding DisplayedElements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="800" Height="580"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="42" Height="48" Margin="0.5" Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="0.5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding AtomicNumber}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,1,0,0" Foreground="#555"/>
                                    <TextBlock Text="{Binding Symbol}" Grid.Row="1" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" Grid.Row="2" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis" Margin="0,0,0,1" Foreground="#666"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding CanvasX}"/>
                            <Setter Property="Canvas.Top" Value="{Binding CanvasY}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Border>
            <Border Grid.Column="1" Background="#F8F9FA" Margin="0,0,5,0" Padding="15" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Элемент" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" Foreground="#1976D2"/>
                        <TextBlock Text="{Binding SelectedElement.Name, FallbackValue='Выберите элемент'}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        <Separator Margin="0,5,0,10" Background="#DDD"/>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Символ: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.Symbol}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Номер: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.AtomicNumber}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Масса: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.AtomicMass, StringFormat={}{0:F3}}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Период: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.PeriodNumber}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Группа: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.GroupNumber}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Тип: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.Category}"/></TextBlock>
                        <TextBlock FontSize="14" Margin="0,4"><Run Text="Сост.: " FontWeight="SemiBold"/><Run Text="{Binding SelectedElement.State}"/></TextBlock>
                        <TextBlock Text="Описание:" Margin="0,15,0,5" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding SelectedElement.Description}" TextWrapping="Wrap" FontSize="14" Foreground="#444" LineHeight="18"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>